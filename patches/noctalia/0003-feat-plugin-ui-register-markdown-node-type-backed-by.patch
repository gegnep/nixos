From 832fea058abba6bae9cc5eaaf81ed4fbe69398ab Mon Sep 17 00:00:00 2001
From: gegnep <96670443+gegnep@users.noreply.github.com>
Date: Tue, 7 Jul 2026 23:54:53 -0400
Subject: [PATCH] feat(plugin-ui): register markdown node type backed by
 MarkdownView

Exposes the existing md4c MarkdownView control to plugin UI trees as
ui.markdown with a text prop. The markdown source is cached per slot
so streaming re-renders only re-parse when the text actually changes.
Links render as underlined text (MarkdownView has no click handling);
sizing follows parent layout like other leaf controls.

Co-Authored-By: Claude Fable 5 <noreply@anthropic.com>
---
 meson.build                   |  3 +++
 src/scripting/ui_prelude.h    |  1 +
 src/ui/ui_tree_reconciler.cpp | 29 +++++++++++++++++++++++++++++
 3 files changed, 33 insertions(+)

diff --git a/meson.build b/meson.build
index 3f99c3a01..5a26e883f 100644
--- a/meson.build
+++ b/meson.build
@@ -1268,6 +1268,7 @@ ui_tree_reconciler_test = executable('ui_tree_reconciler_test',
     'src/ui/controls/image.cpp',
     'src/ui/controls/input.cpp',
     'src/ui/controls/label.cpp',
+    'src/ui/controls/markdown_view.cpp',
     'src/ui/controls/progress_bar.cpp',
     'src/ui/controls/scroll_view.cpp',
     'src/ui/controls/scrollbar.cpp',
@@ -1278,6 +1279,7 @@ ui_tree_reconciler_test = executable('ui_tree_reconciler_test',
     'src/ui/controls/toggle.cpp',
     'src/ui/controls/color_swatch_preview.cpp',
     'src/ui/app_icon_colorization.cpp',
+    'src/ui/builders.cpp',
     'src/ui/palette.cpp',
     'src/ui/style.cpp',
     'src/util/clamp.cpp',
@@ -1316,6 +1318,7 @@ ui_tree_reconciler_test = executable('ui_tree_reconciler_test',
     egl_dep,
     librsvg_dep,
     libwebp_dep,
+    md4c_dep,
     nlohmann_dep,
     xkbcommon_dep,
   ],
diff --git a/src/scripting/ui_prelude.h b/src/scripting/ui_prelude.h
index 1145e3c5b..aacc7254e 100644
--- a/src/scripting/ui_prelude.h
+++ b/src/scripting/ui_prelude.h
@@ -25,6 +25,7 @@ ui.progress = ctor("progress")
 ui.button = ctor("button")
 ui.graph = ctor("graph")
 ui.input = ctor("input")
+ui.markdown = ctor("markdown")
 ui.select = ctor("select")
 ui.slider = ctor("slider")
 ui.toggle = ctor("toggle")
diff --git a/src/ui/ui_tree_reconciler.cpp b/src/ui/ui_tree_reconciler.cpp
index df3cb9ec5..629185b8f 100644
--- a/src/ui/ui_tree_reconciler.cpp
+++ b/src/ui/ui_tree_reconciler.cpp
@@ -12,6 +12,7 @@
 #include "ui/controls/image.h"
 #include "ui/controls/input.h"
 #include "ui/controls/label.h"
+#include "ui/controls/markdown_view.h"
 #include "ui/controls/progress_bar.h"
 #include "ui/controls/scroll_view.h"
 #include "ui/controls/select.h"
@@ -290,6 +291,8 @@ namespace ui {
                                                              "visible",  "value",    "placeholder",  "fontSize",
                                                              "enabled",  "password", "multiline",    "focus",
                                                              "onChange", "onSubmit", "submitOnEnter"};
+      static const std::unordered_set<std::string> kMarkdown = {"width",   "height",  "flexGrow",
+                                                                "opacity", "visible", "text"};
       static const std::unordered_set<std::string> kSelect = {"width",       "height",  "flexGrow",      "opacity",
                                                               "visible",     "options", "selectedIndex", "enabled",
                                                               "placeholder", "onChange"};
@@ -334,6 +337,9 @@ namespace ui {
       if (type == "input") {
         return kInput;
       }
+      if (type == "markdown") {
+        return kMarkdown;
+      }
       if (type == "select") {
         return kSelect;
       }
@@ -360,6 +366,7 @@ namespace ui {
     std::string submitCallbackName;  // last-wired input onSubmit target
     std::string dragEndCallbackName; // last-wired slider onDragEnd target
     std::string imagePath;           // last-applied resolved image source
+    std::string lastText;            // markdown source cache - setMarkdown re-parses, only call on change
     float imageTargetSize = 0.0f;
     // Controlled-with-change-detection: a value-driven control (toggle/slider/
     // select) only re-applies its declared value when it differs from the last
@@ -433,6 +440,9 @@ namespace ui {
     if (desired.type == "input") {
       return std::make_unique<Input>();
     }
+    if (desired.type == "markdown") {
+      return std::make_unique<MarkdownView>();
+    }
     if (desired.type == "select") {
       return std::make_unique<Select>();
     }
@@ -1099,6 +1109,25 @@ namespace ui {
       return;
     }
 
+    if (desired.type == "markdown") {
+      auto* md = static_cast<MarkdownView*>(node);
+      if (const std::string* text = strProp(desired, "text")) {
+        if (*text != slot.lastText) {
+          slot.lastText = *text;
+          md->setMarkdown(*text, m_scale);
+        }
+      }
+      if (width != nullptr) {
+        md->setMinWidth(scaled(*width));
+        md->setMaxWidth(scaled(*width));
+      }
+      if (height != nullptr) {
+        md->setMinHeight(scaled(*height));
+        md->setMaxHeight(scaled(*height));
+      }
+      return;
+    }
+
     if (desired.type == "scroll") {
       auto* scroll = static_cast<ScrollView*>(node);
       if (auto fill = parseColor(desired, "fill")) {
-- 
