+      }
+      ok = expect(
+               inner != nullptr
+                   && inner->minWidth() == 120.0f
+                   && inner->maxWidth() == 120.0f
+                   && inner->minHeight() == 36.0f
+                   && inner->maxHeight() == 36.0f
+                   && measured.width == 120.0f
+                   && measured.height == 36.0f,
+               "clickable container preserves explicit size"
+           )
+          && ok;
+    }
+
