From b5b9fb5a7492ea1cc3440f8aa9494d2fb680340f Mon Sep 17 00:00:00 2001
From: gegnep <96670443+gegnep@users.noreply.github.com>
Date: Tue, 7 Jul 2026 23:53:54 -0400
Subject: [PATCH] feat(plugin-ui): add input submitOnEnter prop for chat-style
 submit

Plugin panels building chat composers need Enter-to-send with
Shift+Enter for newlines. Off by default; existing multiline
behavior (Enter inserts, Ctrl+Enter submits) is unchanged.

Co-Authored-By: Claude Fable 5 <noreply@anthropic.com>
---
 src/ui/controls/input.cpp     | 4 +++-
 src/ui/controls/input.h       | 4 ++++
 src/ui/ui_tree_reconciler.cpp | 5 ++++-
 3 files changed, 11 insertions(+), 2 deletions(-)

diff --git a/src/ui/controls/input.cpp b/src/ui/controls/input.cpp
index b2acceb02..dac0a886d 100644
--- a/src/ui/controls/input.cpp
+++ b/src/ui/controls/input.cpp
@@ -529,6 +529,8 @@ void Input::setOnFocusGain(std::function<void()> callback) { m_onFocusGain = std
 
 void Input::setSubmitOnFocusLoss(bool enabled) { m_submitOnFocusLoss = enabled; }
 
+void Input::setSubmitOnEnter(bool enabled) { m_submitOnEnter = enabled; }
+
 void Input::setSurfaceOpacity(float opacity) {
   const float clamped = std::clamp(opacity, 0.0f, 1.0f);
   if (m_surfaceOpacity == clamped) {
@@ -1228,7 +1230,7 @@ void Input::handleKey(std::uint32_t sym, std::uint32_t utf32, std::uint32_t modi
       }
     }
   } else if (m_multiline && KeySymbol::isEnter(sym) && !preedit) {
-    if (ctrl) {
+    if (ctrl || (m_submitOnEnter && !shift)) {
       if (m_onSubmit) {
         m_onSubmit(m_value);
         if (alive.expired()) {
diff --git a/src/ui/controls/input.h b/src/ui/controls/input.h
index 891bcd9e3..a8f7dd7d9 100644
--- a/src/ui/controls/input.h
+++ b/src/ui/controls/input.h
@@ -57,6 +57,9 @@ public:
   void setOnFocusLoss(std::function<void()> callback);
   void setOnFocusGain(std::function<void()> callback);
   void setSubmitOnFocusLoss(bool enabled);
+  /// Multiline chat-style submit: Enter submits and Shift+Enter inserts a
+  /// newline. Off (default), Enter inserts a newline and Ctrl+Enter submits.
+  void setSubmitOnEnter(bool enabled);
   void setEnabled(bool enabled);
   void setSurfaceOpacity(float opacity);
   void setFrameRadius(float radius);
@@ -217,6 +220,7 @@ private:
   std::function<void()> m_onFocusLoss;
   std::function<void()> m_onFocusGain;
   bool m_submitOnFocusLoss = false;
+  bool m_submitOnEnter = false;
   float m_fontSize = Style::fontSizeBody;
   float m_controlHeight = Style::controlHeight;
   float m_horizontalPadding = Style::spaceMd;
diff --git a/src/ui/ui_tree_reconciler.cpp b/src/ui/ui_tree_reconciler.cpp
index d60b5f37f..3523bba62 100644
--- a/src/ui/ui_tree_reconciler.cpp
+++ b/src/ui/ui_tree_reconciler.cpp
@@ -313,7 +313,7 @@ namespace ui {
       static const std::unordered_set<std::string> kInput = {"width",    "height",   "flexGrow",    "opacity",
                                                              "visible",  "value",    "placeholder", "fontSize",
                                                              "enabled",  "password", "multiline",   "focus",
-                                                             "onChange", "onSubmit", "controlSize"};
+                                                             "onChange", "onSubmit", "controlSize", "submitOnEnter"};
       static const std::unordered_set<std::string> kSelect = {"width",       "height",   "flexGrow",      "opacity",
                                                               "visible",     "options",  "selectedIndex", "enabled",
                                                               "placeholder", "onChange", "controlSize"};
@@ -1100,6 +1100,9 @@ namespace ui {
       if (const bool* multiline = boolProp(desired, "multiline")) {
         input->setMultiline(*multiline);
       }
+      if (const bool* submitOnEnter = boolProp(desired, "submitOnEnter")) {
+        input->setSubmitOnEnter(*submitOnEnter);
+      }
       if (const bool* password = boolProp(desired, "password")) {
         input->setPasswordMode(*password);
       }
-- 
2.54.0

