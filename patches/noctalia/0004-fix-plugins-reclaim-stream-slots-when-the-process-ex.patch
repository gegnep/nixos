From bff2a5b574ffb7b6232914c260f3d08efcfd1356 Mon Sep 17 00:00:00 2001
From: gegnep <96670443+gegnep@users.noreply.github.com>
Date: Wed, 8 Jul 2026 00:46:02 -0400
Subject: [PATCH] fix(plugins): reclaim stream slots when the process exits

runStream slots (kMaxStreamsPerHost = 4) were only released on host
teardown, so a plugin invoking short-lived streaming commands hit the
cap after four runs and every later runStream returned false for the
lifetime of the VM. Exited processes now mark their cancel token via
onExit and startStream sweeps marked tokens before checking the cap.
maxOutputBytes is pinned to 0 so setting onExit does not start
accumulating stream output into RunResult.

Co-Authored-By: Claude Fable 5 <noreply@anthropic.com>
---
 src/scripting/luau_host.cpp | 13 ++++++++++++-
 1 file changed, 12 insertions(+), 1 deletion(-)

diff --git a/src/scripting/luau_host.cpp b/src/scripting/luau_host.cpp
index 4b826dec3..b62525d73 100644
--- a/src/scripting/luau_host.cpp
+++ b/src/scripting/luau_host.cpp
@@ -1506,6 +1506,11 @@ void LuauHost::stateWatch(std::string key, int callbackRef) {
 bool LuauHost::hasStateWatchCallback(int callbackRef) const { return m_stateWatchCallbackRefs.contains(callbackRef); }
 
 bool LuauHost::startStream(std::string command, int callbackRef) {
+  // A stream whose process exited marks its cancel token (see onExit below);
+  // sweep those so finished streams don't count against the cap forever.
+  std::erase_if(m_streamCancels, [](const std::shared_ptr<std::atomic<bool>>& cancel) {
+    return cancel == nullptr || cancel->load(std::memory_order_relaxed);
+  });
   if (command.empty() || callbackRef <= LUA_REFNIL || m_streamCancels.size() >= kMaxStreamsPerHost) {
     return false;
   }
@@ -1540,9 +1545,15 @@ bool LuauHost::startStream(std::string command, int callbackRef) {
     }
   };
 
+  // Mark the token when the process exits so the sweep above can reclaim the
+  // slot. With onExit set the runner would accumulate output into RunResult;
+  // maxOutputBytes = 0 keeps this purely streamed as before.
+  callbacks.onExit = [cancel](process::RunResult) { cancel->store(true, std::memory_order_relaxed); };
+
   process::RunOptions options;
   options.cancel = std::move(cancel);
-  // No timeout (long-lived); no onExit so output is never accumulated, only streamed.
+  options.maxOutputBytes = 0;
+  // No timeout (long-lived).
   return process::runAsync({"/bin/sh", "-c", std::move(command)}, std::move(callbacks), std::move(options));
 }
 
